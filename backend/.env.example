# ── Jay Café Backend Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your values

# MongoDB Connection
# Get free cluster at: https://www.mongodb.com/atlas
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/jaycafe?retryWrites=true&w=majority

# JWT Secret (use any long random string)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_abc123xyz

# Server Port
PORT=5000

# Frontend URL (for CORS)
# Development: http://localhost:5173
# Production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173

# Environment
NODE_ENV=development
